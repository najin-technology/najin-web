# Production URL (used by metadata, sitemap, robots, JSON-LD)
# Fallback: VERCEL_PROJECT_PRODUCTION_URL
NEXT_PUBLIC_SITE_URL=https://your-domain.example.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
# Server-side only (admin invites, user management). NEVER expose to client.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Email notifications
RESEND_API_KEY=your-email-api-key
NOTIFICATION_EMAIL=admin@your-domain.com
FROM_EMAIL=noreply@your-domain.com
# 고객 자동발송 메일의 Reply-To. 고객이 답장하면 이 주소로 옴.
# 미설정 시 NOTIFICATION_EMAIL fallback.
REPLY_TO_EMAIL=admin@your-domain.com

# Bot prevention (CAPTCHA)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-captcha-site-key
TURNSTILE_SECRET_KEY=your-captcha-secret-key

# Redis (rate limiting backend) — auto-injected via marketplace integration
UPSTASH_REDIS_REST_URL=your-redis-url
UPSTASH_REDIS_REST_TOKEN=your-redis-token

# SEO verification (paste `content` attribute value from each console)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=your-naver-verification-code

# Admin OAuth (optional — Naver login on /admin/login)
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# Optional: IP geolocation for analytics (server-side only)
IPINFO_TOKEN=your-ipinfo-token
