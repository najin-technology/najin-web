# Production URL (used by metadata, sitemap, robots, JSON-LD)
# Fallback: VERCEL_PROJECT_PRODUCTION_URL → https://www.najin-tech.com
NEXT_PUBLIC_SITE_URL=https://www.najin-tech.com

# Supabase
NEXT_PUBLIC_SUPABASE_URL=your-supabase-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# Resend (email notifications)
RESEND_API_KEY=your-resend-api-key
NOTIFICATION_EMAIL=admin@your-domain.com
FROM_EMAIL=noreply@your-domain.com

# Cloudflare Turnstile (bot prevention)
# Cloudflare Dashboard → Turnstile → Add site (Invisible mode recommended)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# Upstash Redis (rate limiting) — auto-injected via Vercel Marketplace integration
# Storage → Upstash for Redis → Connect
UPSTASH_REDIS_REST_URL=your-upstash-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-token

# SEO verification (paste `content` attribute value from each console)
# Google Search Console: https://search.google.com/search-console
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your-google-verification-code
# Naver Webmaster Tools: https://searchadvisor.naver.com
NEXT_PUBLIC_NAVER_SITE_VERIFICATION=your-naver-verification-code

# Analytics: 자체 수집만 사용
# /admin/analytics 에 바로 표시. 외부 트래커 (GA4, Naver Analytics) 제거됨.
# Vercel Analytics (성능/Core Web Vitals)은 @vercel/analytics/next 패키지로 자동 수집.
